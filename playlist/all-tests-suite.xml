<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="All Tests Master Suite" parallel="classes" thread-count="4">
    <test name="Pet Module Tests">
        <classes>
            <class name="tests.pet.AddPetTests"/>
            <class name="tests.pet.GetPetTests"/>
            <class name="tests.pet.UpdatePetTests"/>
            <class name="tests.pet.DeletePetTests"/>
            <class name="tests.pet.UploadImageTests"/>
        </classes>
    </test>
    <test name="Store Module Tests">
        <classes>
            <class name="tests.store.GetInventoryTests"/>
            <class name="tests.store.GetOrderTests"/>
            <class name="tests.store.PlaceOrderTests"/>
        </classes>
    </test>
    <test name="User Module Tests">
        <classes>
            <class name="tests.user.CreateUserTests"/>
            <class name="tests.user.GetUserTests"/>
            <class name="tests.user.UpdateUserTests"/>
            <class name="tests.user.DeleteUserTests"/>
            <class name="tests.user.LoginUserTests"/>
        </classes>
    </test>
</suite>
